# Spring Boot 서버의 전체 주소
NUVION_SERVER_BASE_URL=https://api.nuvion-dev.plaidai.io

# Device 계정 (BROADCASTER 역할)
NUVION_DEVICE_USERNAME=sp-<space>-nuvion-<random>
NUVION_DEVICE_PASSWORD=***

# RTP 대상 IP (mediasoup plain transport로 보낼 IP)
NUVION_RTP_REMOTE_IP=34.50.40.188

# H264 파라미터
NUVION_H264_PROFILE_LEVEL_ID=64001f
NUVION_H264_PACKETIZATION_MODE=1
NUVION_H264_LEVEL_ASYMMETRY_ALLOWED=1

# Video source (USB webcam by default). Use "rpi" for Pi camera.
NUVION_VIDEO_SOURCE=/dev/video0

# Detection labels
NUVION_ANOMALY_LABELS=
NUVION_PRODUCTION_LABELS=
NUVION_ANOMALY_CONFIDENCE_THRESHOLD=0.5
NUVION_PRODUCTION_CONFIDENCE_THRESHOLD=0.5
NUVION_ANOMALY_MIN_INTERVAL_SEC=5
NUVION_PRODUCTION_DEDUP_SEC=3

# Optional line/process override
NUVION_LINE_ID=
NUVION_PROCESS_ID=

# Zero-shot anomaly detection (optional)
NUVION_ZERO_SHOT_ENABLED=true
NUVION_ZERO_SHOT_MODEL=google/siglip2-base-patch16-224
NUVION_ZERO_SHOT_LABELS=normal,defect
NUVION_ZERO_SHOT_ANOMALY_LABELS=defect,broken,crack,scratch
NUVION_ZERO_SHOT_THRESHOLD=0.7
NUVION_ZERO_SHOT_SAMPLE_SEC=2

NUVION_ZSAD_BACKEND=triton

# Runtime bootstrap (setup/run에서 자동 모델/도커/Triton 준비)
NUVION_RUNTIME_BOOTSTRAP_ENABLED=true
NUVION_HOMEBREW_AUTOINSTALL=true
NUVION_DOCKER_AUTOINSTALL=true
NUVION_DOCKER_AUTOSTART=true
NUVION_TRITON_AUTOSTART=true
NUVION_TRITON_AUTOSTART_ONLY_LOCAL=true
NUVION_MODEL_AUTO_PULL_ON_SETUP=true
NUVION_MODEL_AUTO_PULL_ON_RUN=true
NUVION_BOOTSTRAP_MAX_RETRIES=3
NUVION_BOOTSTRAP_BACKOFF_SEC=2
NUVION_TRITON_BOOT_TIMEOUT_SEC=40
NUVION_TRITON_CONTAINER_NAME=triton-nuv
NUVION_TRITON_IMAGE=nvcr.io/nvidia/tritonserver:24.10-py3
NUVION_TRITON_MAC_PROFILE=full
NUVION_TRITON_JETSON_PROFILE=runtime

# Model bundle (for `nuv-agent pull-model`)
# source: server (recommended) | gcs (fallback)
NUVION_MODEL_SOURCE=server
NUVION_MODEL_POINTER=anomalyclip/prod
NUVION_MODEL_PRESIGN_TTL_SECONDS=300
NUVION_MODEL_SERVER_BASE_URL=https://api.nuvion-dev.plaidai.io
# Optional: pre-issued bearer token for server source
# NUVION_MODEL_SERVER_ACCESS_TOKEN=
NUVION_MODEL_GCS_POINTER_URI=gs://nuv-model/pointers/anomalyclip/prod.json
NUVION_MODEL_PROFILE=runtime
NUVION_MODEL_DIR=~/.cache/nuvion/models
NUVION_MODEL_LOCAL_DIR=~/.cache/nuvion/models/anomalyclip-current

# Clip upload (pre/post buffer)
NUVION_CLIP_ENABLED=true
NUVION_CLIP_PRE_SEC=5
NUVION_CLIP_POST_SEC=5
NUVION_CLIP_SEGMENT_SEC=1
NUVION_CLIP_MAX_SEGMENTS=30
NUVION_CLIP_OUTPUT_DIR=/tmp/nuvion_clips
NUVION_CLIP_COOLDOWN_SEC=10
NUVION_CLIP_CONTENT_TYPE=video/mp4
# Optional: absolute path to ffmpeg binary (useful in daemon mode)
# NUVION_FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# Agent WebSocket error handling (server /user/queue/agent/error)
NUVION_AGENT_ERROR_MAX_RETRIES=3
NUVION_AGENT_ERROR_BACKOFF_BASE_SEC=1.0
NUVION_AGENT_ERROR_BACKOFF_MAX_SEC=15.0

# Triton (optional)
# generic: single score/logit output
# anomalyclip: image_features + local text_features.npy
NUVION_TRITON_MODE=anomalyclip
NUVION_TRITON_URL=localhost:8000
NUVION_TRITON_MODEL=image_encoder
NUVION_TRITON_INPUT=images
NUVION_TRITON_OUTPUT=OUTPUT__0
NUVION_TRITON_INPUT_FORMAT=NCHW
NUVION_TRITON_INPUT_WIDTH=336
NUVION_TRITON_INPUT_HEIGHT=336
NUVION_TRITON_INPUT_DTYPE=FP32
NUVION_TRITON_INPUT_SCALE=255.0
NUVION_TRITON_THRESHOLD=0.7
NUVION_TRITON_OUTPUT_MODE=logits
NUVION_TRITON_OUTPUT_ACTIVATION=sigmoid
NUVION_TRITON_LABELS=normal,defect
NUVION_TRITON_IMAGE_FEATURES_OUTPUT=image_features
NUVION_TRITON_TEXT_FEATURES=~/.cache/nuvion/models/anomalyclip-current/onnx/text_features.npy
NUVION_TRITON_TEXT_TEMPERATURE=0.07
NUVION_TRITON_ANOMALY_INDEX=1
NUVION_TRITON_NORMALIZE_FEATURES=true
